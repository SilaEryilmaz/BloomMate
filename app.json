{
  "expo": {
    "name": "BloomMate",
    "slug": "period-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "bloomtracker",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF4E8"
      }
    },
    "extra": {
      "privacy": "All cycle data is stored on device in v1."
    }
  }
}
